#!/usr/bin/env bash
set -euo pipefail

# post-session — Orchestrates the full post-processing pipeline after a
# Claude Code session ends. Called by the claude-wrapper in the background.
#
# Usage: post-session <session-dir>

# ---------------------------------------------------------------------------
# Argument validation
# ---------------------------------------------------------------------------

if [[ $# -ne 1 ]]; then
  echo "Usage: post-session <session-dir>" >&2
  exit 1
fi

SESSION_DIR="$1"

if [[ ! -d "$SESSION_DIR" ]]; then
  # Session dir doesn't exist — nothing to do, exit silently
  exit 0
fi

# ---------------------------------------------------------------------------
# Constants & config
# ---------------------------------------------------------------------------

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

CONFIG="${HOME}/.metareview/config.json"
HISTORY="${HOME}/.metareview/history.json"
BIN="${HOME}/.metareview/bin"

# Read config values with defaults
HEURISTICS_AUTO_RUN=true
RAW_LOG_DAYS=7
TRANSCRIPT_DAYS=30

if command -v jq &>/dev/null && [[ -f "$CONFIG" ]]; then
  _har=$(jq -r '.heuristics.auto_run // true' "$CONFIG" 2>/dev/null || true)
  _rld=$(jq -r '.retention.raw_log_days // 7' "$CONFIG" 2>/dev/null || true)
  _trd=$(jq -r '.retention.transcript_days // 30' "$CONFIG" 2>/dev/null || true)
  [[ -n "$_har" ]] && HEURISTICS_AUTO_RUN="$_har"
  [[ -n "$_rld" && "$_rld" != "null" ]] && RAW_LOG_DAYS="$_rld"
  [[ -n "$_trd" && "$_trd" != "null" ]] && TRANSCRIPT_DAYS="$_trd"
fi

SESSION_ID=$(basename "$SESSION_DIR")
RAW_LOG="${SESSION_DIR}/raw.log"
TRANSCRIPT="${SESSION_DIR}/transcript.txt"
META="${SESSION_DIR}/meta.json"

# ---------------------------------------------------------------------------
# Step 1: Clean transcript
# ---------------------------------------------------------------------------

CLEANER="${BIN}/clean-transcript"
if [[ -f "$RAW_LOG" && -x "$CLEANER" ]]; then
  "$CLEANER" "$SESSION_DIR" >/dev/null 2>&1 || true
fi

# ---------------------------------------------------------------------------
# Step 2: Run heuristics
# ---------------------------------------------------------------------------

HEURISTIC_JSON='{"overall":"unknown","total_score":0}'

HEURISTICS_BIN="${BIN}/heuristics"
if [[ "$HEURISTICS_AUTO_RUN" == "true" && -f "$TRANSCRIPT" && -x "$HEURISTICS_BIN" ]]; then
  _result=$("$HEURISTICS_BIN" "$SESSION_DIR" 2>/dev/null || true)
  if [[ -n "$_result" ]] && echo "$_result" | jq -e . >/dev/null 2>&1; then
    HEURISTIC_JSON="$_result"
  fi
fi

# ---------------------------------------------------------------------------
# Step 3: Update meta.json with heuristic scores
# ---------------------------------------------------------------------------

if [[ -f "$META" ]] && command -v jq &>/dev/null; then
  _tmp=$(mktemp "${META}.XXXXXX")
  jq --argjson scores "$HEURISTIC_JSON" '. + {heuristic_score: $scores}' \
    "$META" > "$_tmp" 2>/dev/null && mv "$_tmp" "$META" || { rm -f "$_tmp" || true; }
fi

# ---------------------------------------------------------------------------
# Step 4: Update history.json
# ---------------------------------------------------------------------------

if command -v jq &>/dev/null; then
  # Ensure history.json exists and is a valid array
  if [[ ! -f "$HISTORY" ]]; then
    echo '[]' > "$HISTORY"
  elif ! jq -e 'type == "array"' "$HISTORY" >/dev/null 2>&1; then
    echo '[]' > "$HISTORY"
  fi

  # Read session metadata
  START_TIME=""
  CWD=""
  DURATION_MIN=0
  HEURISTIC_OVERALL="unknown"

  if [[ -f "$META" ]]; then
    START_TIME=$(jq -r '.start_time // ""' "$META" 2>/dev/null || true)
    CWD=$(jq -r '.cwd // ""' "$META" 2>/dev/null || true)
    _dur_secs=$(jq -r '.duration_secs // 0' "$META" 2>/dev/null || echo 0)
    DURATION_MIN=$(( (_dur_secs + 30) / 60 ))
  fi

  HEURISTIC_OVERALL=$(echo "$HEURISTIC_JSON" | jq -r '.overall // "unknown"' 2>/dev/null || echo "unknown")

  _tmp=$(mktemp "${HISTORY}.XXXXXX")
  jq \
    --arg id          "$SESSION_ID" \
    --arg start_time  "$START_TIME" \
    --arg cwd         "$CWD" \
    --argjson duration_min "$DURATION_MIN" \
    --arg heuristic_overall "$HEURISTIC_OVERALL" \
    '. + [{
      id:                 $id,
      start_time:         $start_time,
      cwd:                $cwd,
      duration_min:       $duration_min,
      heuristic_overall:  $heuristic_overall,
      reviewed:           false
    }]' "$HISTORY" > "$_tmp" 2>/dev/null && mv "$_tmp" "$HISTORY" || { rm -f "$_tmp" || true; }
fi

# ---------------------------------------------------------------------------
# Step 5: Retention pruning
# ---------------------------------------------------------------------------

SESSIONS_DIR="${HOME}/.metareview/sessions"

# Delete raw.log files older than raw_log_days
if [[ -d "$SESSIONS_DIR" ]]; then
  find "$SESSIONS_DIR" -name "raw.log" -mtime +"$RAW_LOG_DAYS" -delete 2>/dev/null || true
  # Delete markers.jsonl files older than raw_log_days
  find "$SESSIONS_DIR" -name "markers.jsonl" -mtime +"$RAW_LOG_DAYS" -delete 2>/dev/null || true
  # Delete transcript.txt files older than transcript_days
  find "$SESSIONS_DIR" -name "transcript.txt" -mtime +"$TRANSCRIPT_DAYS" -delete 2>/dev/null || true
  # Delete empty session directories (no files inside)
  find "$SESSIONS_DIR" -mindepth 1 -maxdepth 1 -type d -empty -delete 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Step 6: Print terminal summary
# ---------------------------------------------------------------------------

# Compute human-readable size from raw.log or transcript.txt
SIZE_BYTES=0
if [[ -f "$RAW_LOG" ]]; then
  SIZE_BYTES=$(wc -c < "$RAW_LOG" | tr -d ' ')
elif [[ -f "$TRANSCRIPT" ]]; then
  SIZE_BYTES=$(wc -c < "$TRANSCRIPT" | tr -d ' ')
elif [[ -f "$META" ]]; then
  SIZE_BYTES=$(jq -r '.transcript_bytes // 0' "$META" 2>/dev/null || echo 0)
fi

# Format size human-readable
if [[ "$SIZE_BYTES" -ge 1048576 ]]; then
  SIZE_HR="$(( SIZE_BYTES / 1048576 ))MB"
elif [[ "$SIZE_BYTES" -ge 1024 ]]; then
  SIZE_HR="$(( SIZE_BYTES / 1024 ))KB"
else
  SIZE_HR="${SIZE_BYTES}B"
fi

# Re-read duration_min from meta.json (may have been updated)
if [[ -f "$META" ]] && command -v jq &>/dev/null; then
  _dur_secs=$(jq -r '.duration_secs // 0' "$META" 2>/dev/null || echo 0)
  DURATION_MIN=$(( (_dur_secs + 30) / 60 ))
fi

OVERALL=$(echo "$HEURISTIC_JSON" | jq -r '.overall // "unknown"' 2>/dev/null || echo "unknown")

# Extract signal counts
CORRECTION_CYCLES=$(echo "$HEURISTIC_JSON" | jq -r '.correction_cycles // 0' 2>/dev/null || echo 0)
SORRY_LOOPS=$(echo "$HEURISTIC_JSON" | jq -r '.sorry_loops // 0' 2>/dev/null || echo 0)
FRUSTRATION_SIGNALS=$(echo "$HEURISTIC_JSON" | jq -r '.frustration_signals // 0' 2>/dev/null || echo 0)
UNCLAIMED_DELIVERABLES=$(echo "$HEURISTIC_JSON" | jq -r '.unclaimed_deliverables // 0' 2>/dev/null || echo 0)
REPETITIONS=$(echo "$HEURISTIC_JSON" | jq -r '.repetitions // 0' 2>/dev/null || echo 0)
TOTAL_SCORE=$(echo "$HEURISTIC_JSON" | jq -r '.total_score // 0' 2>/dev/null || echo 0)

BASE_LINE="${BOLD}[metareview]${NC} Session ${CYAN}${SESSION_ID}${NC} captured (${DURATION_MIN}min, ${SIZE_HR})"

case "$OVERALL" in
  green)
    printf "${GREEN}${BASE_LINE}${NC}\n" >&2
    printf "${GREEN}Heuristic scan: green (score: ${TOTAL_SCORE})${NC}\n" >&2
    ;;
  yellow)
    printf "${YELLOW}${BASE_LINE}${NC}\n" >&2
    printf "${YELLOW}Heuristic scan: yellow (score: ${TOTAL_SCORE})${NC}\n" >&2
    printf "${YELLOW}  %d correction cycles, %d frustration signals, %d sorry loops, %d repetitions, %d unclaimed deliverables${NC}\n" \
      "$CORRECTION_CYCLES" "$FRUSTRATION_SIGNALS" "$SORRY_LOOPS" "$REPETITIONS" "$UNCLAIMED_DELIVERABLES" >&2
    ;;
  red)
    printf "${RED}${BASE_LINE}${NC}\n" >&2
    printf "${RED}Heuristic scan: red (score: ${TOTAL_SCORE})${NC}\n" >&2
    printf "${RED}  %d correction cycles, %d frustration signals, %d sorry loops, %d repetitions, %d unclaimed deliverables${NC}\n" \
      "$CORRECTION_CYCLES" "$FRUSTRATION_SIGNALS" "$SORRY_LOOPS" "$REPETITIONS" "$UNCLAIMED_DELIVERABLES" >&2
    printf "${RED}Run ${BOLD}metareview ${SESSION_ID}${NC}${RED} for full analysis${NC}\n" >&2
    ;;
  *)
    # unknown — heuristics didn't run (e.g., no transcript)
    printf "${BOLD}[metareview]${NC} Session ${CYAN}${SESSION_ID}${NC} captured (${DURATION_MIN}min, ${SIZE_HR})\n" >&2
    ;;
esac
